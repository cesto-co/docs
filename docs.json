{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Cesto",
  "description": "Invest in narrative-driven baskets of assets on Solana. Docs for the Cesto product, the Cesto SDK, the Cesto Toolkit agent skill, and embeddable basket widgets.",
  "colors": {
    "primary": "#16A34A",
    "light": "#16A34A",
    "dark": "#16A34A"
  },
  "favicon": "https://res.cloudinary.com/dcyihhgo6/image/upload/cesto_favicon.png",
  "seo": {
    "indexing": "all"
  },
  "integrations": {
    "ga4": {
      "measurementId": "G-GDY7882MCE"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Cesto",
            "pages": [
              "cesto/what-is-cesto",
              "cesto/how-it-works"
            ]
          },
          {
            "group": "Using Cesto",
            "pages": [
              "cesto/funding",
              "cesto/my-portfolio",
              "cesto/rebalancing"
            ]
          },
          {
            "group": "Community & Creators",
            "pages": [
              "cesto/labs",
              "cesto/creators"
            ]
          },
          {
            "group": "Skills",
            "pages": [
              "cesto/skill"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "cesto/security",
              "cesto/faq"
            ]
          }
        ]
      },
      {
        "tab": "Developers",
        "icon": "code",
        "groups": [
          {
            "group": "Cesto SDK",
            "pages": [
              "sdk/overview",
              "sdk/integration-models",
              "sdk/authentication",
              "sdk/configuration",
              "sdk/products",
              "sdk/positions",
              "sdk/open-position",
              "sdk/close-position",
              "sdk/rebalance-position",
              "sdk/errors",
              "sdk/examples"
            ]
          }
        ]
      },
      {
        "tab": "Widgets",
        "icon": "shapes",
        "groups": [
          {
            "group": "Widgets",
            "pages": [
              "widgets/overview",
              "widgets/usage",
              "widgets/playground"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/plugins",
      "destination": "/widgets/overview"
    },
    {
      "source": "/plugins/overview",
      "destination": "/widgets/overview"
    },
    {
      "source": "/plugins/usage",
      "destination": "/widgets/usage"
    },
    {
      "source": "/plugins/playground",
      "destination": "/widgets/playground"
    },
    {
      "source": "/plugins/:slug*",
      "destination": "/widgets/:slug*"
    }
  ],
  "logo": {
    "light": "https://res.cloudinary.com/dcyihhgo6/image/upload/cesto-logo-light.svg",
    "dark": "https://res.cloudinary.com/dcyihhgo6/image/upload/cesto-logo.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "SDK",
        "icon": "code",
        "href": "https://docs.cesto.co/sdk/overview"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://app.cesto.co"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/cesto_co",
      "telegram": "https://t.me/cesto_co",
      "website": "https://cesto.co"
    }
  }
}
